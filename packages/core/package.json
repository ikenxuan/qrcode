{
  "name": "@ikenxuan/qrcode",
  "version": "1.0.0",
  "type": "module",
  "description": "基于 Rust qr-code-styling 的高性能 QR 码生成器",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
